# Metis Research Cortex — MCP-only light image
# Runs only the MCP server (AI tools for Claude Desktop).
# No dashboard, no browser interface — half the size.
#
# Use this if you only want Metis tools in Claude Desktop,
# without the browser dashboard.
#
# Usage:
#   docker build -f Dockerfile.light -t metis-mcp-light .
#   docker run -i \
#     -v /path/to/your/metis:/metis \
#     -e ANTHROPIC_API_KEY=sk-ant-... \
#     metis-mcp-light
#
# Claude Desktop config (claude_desktop_config.json):
#   "metis-rc": {
#     "command": "docker",
#     "args": ["run", "-i", "--rm",
#       "-v", "/path/to/metis:/metis",
#       "-e", "ANTHROPIC_API_KEY=sk-ant-...",
#       "metis-mcp-light"]
#   }

FROM python:3.11-slim

LABEL maintainer="Metis Project"
LABEL description="Metis Research Cortex — MCP server only (light)"

# ── System dependencies ───────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsqlite3-dev \
    libffi-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ── Python environment ────────────────────────────────────────────────────────
WORKDIR /app

COPY metis/system/mcp-server/pyproject.toml .
COPY metis/system/mcp-server/src ./src

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e ".[voice]"

# Copy agents and config (no personal data, no dashboard)
COPY metis/agents ./metis/agents
COPY metis/.claude ./metis/.claude
COPY metis/system/config ./metis/system/config

# ── Runtime configuration ─────────────────────────────────────────────────────
ENV METIS_RC_ROOT=/metis
ENV PYTHONPATH=/app/src
ENV METIS_DOCKER=1

# MCP communicates via stdio — no port to expose

# ── Entrypoint ────────────────────────────────────────────────────────────────
CMD ["python", "-m", "metis_mcp.server"]
