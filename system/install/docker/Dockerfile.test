ARG BASE_IMAGE=ubuntu:22.04
FROM ${BASE_IMAGE}

# System prerequisites — curl for uv, python3 as fallback, git for any clone ops
RUN apt-get update -qq \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y \
       curl python3 python3-pip git sudo \
    && rm -rf /var/lib/apt/lists/*

# Code is mounted at /opt/metis (read-only) by docker-compose.test.yml
# Data lives at /opt/metis-data (writable volume — no personal data)
ENV METIS_RC_ROOT=/opt/metis-data
ENV PYTHONUNBUFFERED=1

EXPOSE 8080

ENTRYPOINT ["/opt/metis/system/install/docker/test-entrypoint.sh"]
