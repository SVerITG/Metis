# Dockerfile.glama — minimal image for Glama's MCP introspection check.
#
# Glama builds this image, starts the MCP server over stdio, and verifies it
# responds to `initialize` + `tools/list`. It does NOT need the dashboard, a
# populated library, or a database — just the server registering its tools.
# (Verified locally: initialize -> ok, tools/list -> 175 tools.)
#
# Build context = the Metis_PH repo root.

FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir --upgrade pip

# Only what the MCP server needs to register + introspect its tools/prompts.
COPY system/mcp-server /app/system/mcp-server
COPY agents            /app/agents
COPY .claude           /app/.claude
COPY system/config     /app/system/config

# [embedding] keeps the knowledge tools registerable; the ONNX model is fetched
# lazily at first use (never during introspection), so the build stays light.
RUN pip install --no-cache-dir -e "system/mcp-server/.[embedding]"

ENV METIS_RC_ROOT=/app
ENV METIS_TOOL_SUBSETS=0
ENV METIS_DOCKER=1

# FastMCP stdio server — this is what Glama introspects.
CMD ["python", "-m", "metis_mcp.server"]
