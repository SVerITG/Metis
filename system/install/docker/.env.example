# Metis Research Cortex — Environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to git — it contains secret keys.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Path to your Metis research folder on the host machine.
# Mounted read-write into the container at /metis.
#   Linux/macOS:  METIS_DATA_DIR=/home/yourname/Documents/Metis
#   Windows WSL:  METIS_DATA_DIR=/mnt/c/Users/yourname/Documents/Metis
#   Windows path: METIS_DATA_DIR=C:/Users/yourname/Documents/Metis
METIS_DATA_DIR=~/Documents/Metis

# ── Optional — Zotero integration ────────────────────────────────────────────
# Required only if you use /librarian with Zotero sync.
# Get your key at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_USER_ID=
# ZOTERO_GROUP_ID=
# ZOTERO_ROOT=/home/yourname/Zotero/storage

# ── Optional — Extra AI providers ────────────────────────────────────────────
# Gemini — used by some agents as a secondary model
GEMINI_API_KEY=

# Hugging Face — used for local model downloads (Whisper, etc.)
HF_API_TOKEN=

# ── Optional — Voice transcription ───────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower. "base" is a good default.
METIS_WHISPER_MODEL=base

# ── Optional — Dashboard ─────────────────────────────────────────────────────
# Change if 8080 is already in use on your machine.
DASHBOARD_PORT=8080

# Pull a specific image version instead of :latest
# METIS_IMAGE=ghcr.io/sveritg/metis:1.0
