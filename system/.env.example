# Metis Research Cortex — Environment variables template
# Copy this file to .env and fill in your values:
#   cp system/.env.example system/.env
# Never commit .env to git — it contains secret keys.
# Note: WSL interop is disabled on some systems — Windows env vars may not be
#       visible to WSL processes. Always set these directly in this file.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key (https://console.anthropic.com)
# The key starts with sk-ant-...
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Optional — Zotero integration ─────────────────────────────────────────────
# Required only if you use /librarian with Zotero sync.
# Get your key at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your-zotero-api-key-here
ZOTERO_USER_ID=your-zotero-user-id-here
# ZOTERO_GROUP_ID=your-zotero-group-id-here
# ZOTERO_ROOT=/home/<username>/Zotero/storage

# ── Optional — Extra AI providers ─────────────────────────────────────────────
# Gemini — used by some agents as a secondary model
# GEMINI_API_KEY=your-gemini-api-key-here

# Hugging Face — used for local model downloads (Whisper, etc.)
# HF_API_TOKEN=your-huggingface-token-here

# ── Optional — Voice transcription ────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower. "base" is a good default.
# METIS_WHISPER_MODEL=base

# ── Optional — Dashboard port ─────────────────────────────────────────────────
# Change if 8080 is already in use on your machine.
# DASHBOARD_PORT=8080
