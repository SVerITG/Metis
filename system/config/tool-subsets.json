{
  "version": "1.1",
  "description": "Agent-to-tool-group mapping. The MCP server loads only the tools each agent needs, reducing context token cost by 50-80%. Set METIS_TOOL_SUBSETS=1 in run.sh to activate (default). Set METIS_TOOL_SUBSETS=0 to load all tools (developer mode).",
  "groups": {
    "literature":   ["library", "literature", "literature_monitor", "knowledge_graph", "ref_miner", "fulltext_index", "zotero", "research", "paperqa_search"],
    "writing":      ["notes", "ideas", "brainstorm", "thinking_profile", "files", "observation"],
    "methods":      ["ideas", "notes", "files", "research", "literature", "paperqa_search"],
    "data":         ["data_tools", "anonymization", "files", "safety", "guardrails"],
    "admin":        ["projects", "tasks", "config_tools", "user_profile", "handoff", "project_tracker"],
    "intelligence": ["intelligence", "content_scan", "memory", "vector_memory", "improvement", "self_improvement"],
    "sessions":     ["session_memory", "memory_curator"],
    "meetings":     ["meetings"],
    "security":     ["safety", "guardrails", "anonymization", "doctor"],
    "media":        ["transcription", "images", "files", "voice_capture"],
    "pipeline":     ["agents", "pipeline", "observability", "handoff", "improvement", "self_improvement", "user_profile"],
    "courses":      ["course_builder", "knowledge_db"],
    "specialist":   ["dhis2", "research_timeline", "knowledge_graph", "knowledge_db"]
  },
  "agents": {
    "librarian":           ["literature", "admin", "writing", "sessions"],
    "meeting-memory":      ["media", "meetings", "admin", "writing", "sessions"],
    "software-engineer":   ["admin", "security", "writing", "data", "sessions"],
    "methods-coach":       ["methods", "writing", "sessions"],
    "epidemiologist":      ["methods", "literature", "writing", "sessions"],
    "news-radar":          ["intelligence", "writing", "sessions"],
    "news-aggregator":     ["intelligence", "writing", "sessions"],
    "course-builder":      ["literature", "admin", "writing", "courses", "sessions"],
    "data-analyst":        ["data", "admin", "sessions"],
    "data-guardian":       ["security", "data", "sessions"],
    "phd-architect":       ["admin", "literature", "writing", "sessions"],
    "writing-partner":     ["writing", "admin", "sessions"],
    "content-harvester":   ["literature", "media", "writing", "sessions"],
    "learning-architect":  ["admin", "writing", "courses", "sessions"],
    "learning-coach":      ["admin", "writing", "literature", "sessions"],
    "visualization-maker": ["writing", "data", "sessions"],
    "dhis2-expert":        ["specialist", "admin", "writing", "sessions"],
    "biostatistician":     ["methods", "literature", "data", "writing", "sessions"],
    "background-maker":    ["literature", "media", "specialist", "sessions"],
    "metis":               ["pipeline", "intelligence", "admin", "sessions", "meetings"],
    "_default":            "all"
  },
  "_comment_default": "_default is the subset loaded when no METIS_AGENT_SUBSET is set — i.e. the general interactive session used by Claude Desktop AND the Claude Code main 'metis-rc' connection. Both have ONE connection and ONE subset for the whole session (no per-agent relaunch), so the default MUST expose every tool — otherwise capabilities like the routed knowledge layer (search_pdf_knowledge), DHIS2, data tools, transcription and voice are unreachable. Hence 'all'. The per-agent subsets above still apply ONLY when METIS_AGENT_SUBSET=<slug> is set explicitly (e.g. token-optimized automation launchers). Set METIS_TOOL_SUBSETS=0 to disable the mechanism entirely."
}
