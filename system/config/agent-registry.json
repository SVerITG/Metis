{
  "_meta": {
    "version": "1.0",
    "last_updated": "2026-05-26",
    "purpose": "Machine-readable registry of all Research Cortex agents. Single source of truth for trust tiers, permission constraints, allowed paths, and output conventions. Derived from Claude Code architecture principles (metadata-first design, permission tiers, type constraints).",
    "trust_tiers": {
      "gate-keeper": "Blocking or veto authority over other agents. No internet. Operates locally only. Cannot be overridden by user for SENSITIVE data blocks.",
      "orchestrator": "Full routing and delegation authority. Read/write local. Internet requires explicit permission each time.",
      "write-external": "Can access internet within a defined scope. Writes output files locally. Scope is pre-approved per agent.",
      "write-local": "No internet access. Can read and write files within allowed_paths only.",
      "read-advise": "Advisory or propose-only role. Does not create files without explicit approval. May read broadly."
    }
  },
  "agents": [
    {
      "slug": "metis",
      "name": "Metis",
      "invocation": "/metis",
      "trust_tier": "orchestrator",
      "description": "Senior researcher and RC orchestrator. Default entry point. Routes all requests to specialist agents, records all work, manages inbox triage and daily/weekly summaries.",
      "internet": false,
      "internet_requires_approval": true,
      "internet_scope": null,
      "allowed_paths": [
        "*"
      ],
      "forbidden_actions": [
        "delete_files_without_approval",
        "send_data_externally",
        "skip_recording_substantive_work",
        "use_internet_silently"
      ],
      "requires_approval_before": [
        "internet_access",
        "file_deletion",
        "folder_reorganization",
        "external_sync_or_upload"
      ],
      "can_act_without_approval": [
        "read_local_files",
        "write_output_files",
        "log_agent_runs",
        "update_local_metadata",
        "create_draft_notes_and_tasks"
      ],
      "output_path": "outputs/reviews/",
      "complexity_levels": [
        "quick",
        "standard",
        "deep",
        "chain"
      ],
      "chains_with": [
        "all"
      ]
    },
    {
      "slug": "cybersecurity",
      "name": "Cybersecurity Agent",
      "invocation": "/cybersecurity",
      "trust_tier": "gate-keeper",
      "description": "Security guardian. Reviews internet requests from other agents, detects prompt injection, validates URLs against domain allowlist, audits agent scope compliance. Has veto authority over internet requests.",
      "internet": false,
      "internet_requires_approval": false,
      "internet_scope": null,
      "note": "Does NOT access the internet directly. Reviews what other agents are about to access. This prevents the security agent itself from being compromised.",
      "veto_scope": [
        "internet requests targeting domains not in system/config/security/domain-allowlist.txt",
        "content containing prompt injection patterns",
        "internet access attempts by agents without internet permission"
      ],
      "allowed_paths": [
        "system/config/security/",
        "outputs/reviews/cybersecurity/"
      ],
      "forbidden_actions": [
        "direct_internet_access",
        "approve_own_requests",
        "bypass_domain_allowlist"
      ],
      "requires_approval_before": [],
      "can_act_without_approval": [
        "block_internet_requests_matching_injection_patterns",
        "alert_user_on_security_incident",
        "read_domain_allowlist_and_blocklist",
        "write_security_log"
      ],
      "output_path": "outputs/reviews/cybersecurity/",
      "chains_with": [
        "data-guardian",
        "metis"
      ]
    },
    {
      "slug": "data-guardian",
