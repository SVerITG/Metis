{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch|WebSearch|Bash|Write|Edit|Read|mcp__metis-rc__read_file",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-tool-use.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/post-tool-use.mjs\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/stop.mjs\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/pre-compact.mjs\""
          }
        ]
      }
    ]
  }
}
