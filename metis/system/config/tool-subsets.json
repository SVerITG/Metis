{
  "version": "1.0",
  "description": "Agent-to-tool-group mapping for domain-specific tool loading. Groups tools into domain subsets so each agent only loads the tools it needs — estimated 50-80% input token reduction. The loading code is not yet active; this config defines the intent.",
  "note": "Loading enforcement is Phase D (XL). This file is read by the MCP server when domain-specific loading is enabled via METIS_TOOL_SUBSETS=1.",
  "groups": {
    "literature": ["library", "literature", "literature_monitor", "knowledge_graph", "ref_miner", "fulltext_index", "zotero", "research"],
    "writing": ["notes", "ideas", "brainstorm", "thinking_profile", "files"],
    "methods": ["ideas", "notes", "files", "research", "literature"],
    "data": ["data_tools", "anonymization", "files", "safety", "guardrails"],
    "admin": ["projects", "tasks", "config_tools", "user_profile", "handoff", "observability"],
    "intelligence": ["intelligence", "content_scan", "memory", "vector_memory", "improvement", "self_improvement"],
    "security": ["safety", "guardrails", "anonymization", "doctor"],
    "media": ["transcription", "images", "files"],
    "pipeline": ["agents", "pipeline", "observability", "handoff", "improvement", "self_improvement", "user_profile"]
  },
  "agents": {
    "librarian":              ["literature", "admin", "writing"],
    "meeting-memory":         ["media", "admin", "writing"],
    "software-engineer":      ["admin", "security", "writing", "data"],
    "methods-coach":          ["methods", "writing"],
    "epidemiologist":         ["methods", "literature", "writing"],
    "news-radar":             ["intelligence", "writing"],
    "news-aggregator":        ["intelligence", "writing"],
    "course-builder":         ["literature", "admin", "writing", "methods"],
    "data-analyst":           ["data", "admin"],
    "data-guardian":          ["security", "data"],
    "phd-architect":          ["admin", "literature", "writing"],
    "writing-partner":        ["writing", "admin"],
    "content-harvester":      ["literature", "media", "writing"],
    "learning-architect":     ["admin", "writing"],
    "learning-coach":         ["admin", "writing", "literature"],
    "visualization-maker":    ["writing", "data"],
    "metis":                  ["pipeline", "intelligence", "admin"],
    "_default":               "all"
  }
}
