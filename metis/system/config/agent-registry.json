      "trust_tier": "gate-keeper",
      "description": "Data privacy enforcer. Detects PII and medical data, classifies data sensitivity, blocks transmission of SENSITIVE data. Has blocking authority — SENSITIVE data blocks are never overridden.",
      "internet": false,
      "internet_requires_approval": false,
      "internet_scope": null,
      "blocking_scope": {
        "SENSITIVE": "Always blocks — no user override. Covers patient records, individual case data, medical identifiers.",
        "CONFIDENTIAL": "Blocks until user explicitly confirms.",
        "data_files": "Blocks Excel/.csv/database files from leaving local machine until user confirms.",
        "original_content": "Warns once, proceeds if user acknowledges."
      },
      "allowed_paths": [
        "system/config/security/",
        "outputs/reviews/data-guardian/"
      ],
      "forbidden_actions": [
        "direct_internet_access",
