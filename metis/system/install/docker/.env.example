# Metis Research Cortex — Environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Path to your research data folder on the host machine.
# This is mounted into the container at /metis.
# Examples:
#   Linux/Mac:  METIS_DATA_DIR=/home/yourname/Documents/Metis
#   Windows:    METIS_DATA_DIR=C:/Users/yourname/Documents/Metis
METIS_DATA_DIR=~/Documents/Metis
