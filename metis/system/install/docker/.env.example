# Metis Research Cortex — Environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────
# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Path to your research data folder on the host machine.
# Mounted read/write inside the container at /metis.
# Examples:
#   Linux/Mac:  METIS_DATA_DIR=/home/yourname/Documents/Metis
#   Windows WSL: METIS_DATA_DIR=/mnt/c/Users/yourname/Documents/Metis
METIS_DATA_DIR=~/Documents/Metis

# ── Optional ─────────────────────────────────────────────────────────────────
# Pull a specific image version instead of :latest
# METIS_IMAGE=ghcr.io/sveritg/metis:1.0

# Dashboard port (default 8080)
# DASHBOARD_PORT=8080

# Zotero storage path (if you use Zotero for PDF management)
# ZOTERO_ROOT=/home/yourname/Zotero/storage
