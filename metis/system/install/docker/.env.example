# Metis Docker — environment variables
# Copy this file to .env and fill in your values.

# Required: your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Path to your research data directory on the host machine
# This folder will contain your PDFs, notes, database, etc.
# It is mounted into the container — data stays on your machine.
METIS_DATA_DIR=~/Documents/Metis

# Optional: Hugging Face token for speaker diarization in meeting transcripts
# HF_TOKEN=hf_...

# Optional: override the default faster-whisper model size
# Options: tiny, base, small, medium, large-v3
# METIS_WHISPER_MODEL=base
