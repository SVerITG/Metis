# ── Personal content (never push to GitHub) ──────────────────────────────────
# These contain the user's personal research data.
# They stay on your machine but are never committed.
metis/journal/
metis/inbox/
metis/inputs/meetings/
metis/outputs/reviews/
metis/projects/active/
metis/archive/
metis/knowledge/library/disease-areas/
metis/knowledge/library/reading-lists/
metis/knowledge/library/people-organizations/

# Personal agent overlay files. Only *-context.md and the user-specific
# `sources.md` overlays are gitignored — all generic skill.md / system-prompt.md
# files are tracked so a fresh clone is functional out of the box.
metis/agents/**/*-context.md
metis/agents/librarian/sources.md
metis/agents/news-radar/sources.md

