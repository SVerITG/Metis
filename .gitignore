metis-functional-test.docx

# Personal agent overlay files. Only *-context.md and the user-specific
# `sources.md` overlays are gitignored — all generic skill.md / system-prompt.md
# files are tracked so a fresh clone is functional out of the box.
metis/agents/**/*-context.md
metis/agents/librarian/sources.md
metis/agents/news-radar/sources.md

# Private agent: Release Coordinator (contains personal repo graph, credentials
# patterns, and PH-specific propagation rules — never ship to GitHub)
metis/agents/release-coordinator/

# Per-user config and session state
metis/system/config/user-preferences.json
metis/system/config/user-config.yaml
